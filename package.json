{
    "name": "lyjy-obsidianlike-md",
    "displayName": "Lyjy ObsidianLike MD for VS Code",
    "description": "WYSIWYG Markdown editor for VS Code with Obsidian-style live preview. Tables, Mermaid diagrams, KaTeX math, code block syntax highlighting, and full IME support.",
    "version": "0.3.11",
    "publisher": "lyjy-kq",
    "license": "SEE LICENSE IN LICENSE",
    "repository": {
        "type": "git",
        "url": "https://github.com/lyjy-kq/lyjy-obsidianlike-md-forvscode"
    },
    "bugs": {
        "url": "https://github.com/lyjy-kq/lyjy-obsidianlike-md-forvscode/issues"
    },
    "homepage": "https://github.com/lyjy-kq/lyjy-obsidianlike-md-forvscode#readme",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "markdown",
        "markdown editor",
        "wysiwyg",
        "obsidian",
        "live preview",
        "mermaid",
        "katex",
        "table",
        "code block",
        "math"
    ],
    "galleryBanner": {
        "color": "#272b33",
        "theme": "dark"
    },
    "markdown": "github",
    "qna": "marketplace",
    "activationEvents": [
        "onCustomEditor:flowMd.editor",
        "onCommand:flowMd.exportAsHtml"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "configurationDefaults": {
            "workbench.editorAssociations": {
                "{git,gist}:/**/*.md": "default"
            }
        },
        "customEditors": [
            {
                "viewType": "flowMd.editor",
                "displayName": "FlowMD Editor",
                "selector": [
                    {
                        "filenamePattern": "*.md",
                        "scheme": "file"
                    },
                    {
                        "filenamePattern": "*.md",
                        "scheme": "untitled"
                    }
                ],
                "priority": "default"
            }
        ],
        "commands": [
            {
                "command": "flowMd.openWith",
                "title": "Open with FlowMD",
                "category": "FlowMD"
            },
            {
                "command": "flowMd.enterViewerMode",
                "title": "FlowMD: Viewer Mode",
                "category": "FlowMD",
                "icon": "$(book)"
            },
            {
                "command": "flowMd.enterSourceMode",
                "title": "FlowMD: Source Mode",
                "category": "FlowMD",
                "icon": "$(code)"
            },
            {
                "command": "flowMd.enterLiveMode",
                "title": "FlowMD: Live Preview Mode",
                "category": "FlowMD",
                "icon": "$(edit)"
            },
            {
                "command": "flowMd.find",
                "title": "FlowMD: Find",
                "category": "FlowMD"
            },
            {
                "command": "flowMd.replace",
                "title": "FlowMD: Find and Replace",
                "category": "FlowMD"
            },
            {
                "command": "flowMd.exportAsHtml",
                "title": "Export as HTML",
                "category": "FlowMD"
            },
            {
                "command": "flowMd.insertImage",
                "title": "Insert Image",
                "category": "FlowMD",
                "icon": "$(file-media)"
            },
            {
                "command": "flowMd.insertImageFromExplorer",
                "title": "Insert into FlowMD",
                "category": "FlowMD",
                "icon": "$(file-media)"
            }
        ],
        "keybindings": [
            {
                "command": "flowMd.find",
                "key": "ctrl+f",
                "mac": "cmd+f",
                "when": "activeCustomEditorId == flowMd.editor"
            },
            {
                "command": "flowMd.replace",
                "key": "ctrl+h",
                "mac": "cmd+alt+f",
                "when": "activeCustomEditorId == flowMd.editor"
            },
            {
                "command": "flowMd.noop",
                "key": "ctrl+z",
                "mac": "cmd+z",
                "when": "activeCustomEditorId == flowMd.editor"
            },
            {
                "command": "flowMd.noop",
                "key": "ctrl+shift+z",
                "mac": "cmd+shift+z",
                "when": "activeCustomEditorId == flowMd.editor"
            },
            {
                "command": "flowMd.noop",
                "key": "ctrl+y",
                "mac": "cmd+y",
                "when": "activeCustomEditorId == flowMd.editor"
            },
            {
                "command": "flowMd.insertImage",
                "key": "ctrl+shift+i",
                "mac": "cmd+shift+i",
                "when": "activeCustomEditorId == flowMd.editor"
            }
        ],
        "menus": {
            "explorer/context": [
                {
                    "command": "flowMd.openWith",
                    "when": "resourceExtname == .md",
                    "group": "navigation"
                },
                {
                    "command": "flowMd.insertImageFromExplorer",
                    "when": "activeCustomEditorId == flowMd.editor && resourceExtname =~ /^\\.(png|jpg|jpeg|gif|webp|svg|bmp)$/i",
                    "group": "navigation@2"
                },
                {
                    "command": "flowMd.exportAsHtml",
                    "when": "resourceExtname == .md",
                    "group": "1_modification"
                }
            ]
        },
        "configuration": {
            "title": "FlowMD",
            "properties": {
                "flowMd.largeFileWarningThreshold": {
                    "type": "number",
                    "default": 1048576,
                    "minimum": 0,
                    "description": "Large file warning threshold in bytes. Set to 0 to disable."
                },
                "flowMd.syncDebounceMs": {
                    "type": "number",
                    "default": 300,
                    "minimum": 50,
                    "maximum": 2000,
                    "description": "Sync debounce time in milliseconds"
                },
                "flowMd.enableDebugLog": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable verbose debug logging. Logs appear in the Output panel (View > Output > FlowMD)."
                },
                "flowMd.lineNumbers": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show line numbers"
                },
                "flowMd.wordWrap": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable word wrap for long lines"
                },
                "flowMd.readableLineLength": {
                    "type": "number",
                    "default": 900,
                    "minimum": 0,
                    "description": "Max content width in pixels. Set to 0 for unlimited. Default: 900"
                },
                "flowMd.fontScale": {
                    "type": "number",
                    "default": 1,
                    "minimum": 0.5,
                    "maximum": 2,
                    "description": "Editor body font size scale. Ctrl+wheel changes this value and saves it automatically.",
                    "markdownDescription": "编辑器正文的字体大小缩放倍率。按 `Ctrl+滚轮` 调整后会自动保存。"
                },
                "flowMd.theme": {
                    "type": "string",
                    "enum": [
                        "auto",
                        "dark",
                        "light"
                    ],
                    "default": "auto",
                    "description": "Theme setting (auto: follow VS Code theme)"
                },
                "flowMd.imageSaveFolder": {
                    "type": "string",
                    "default": "images",
                    "description": "Folder name for saved images (relative to .md file). Default: images"
                },
                "flowMd.defaultMode": {
                    "type": "string",
                    "enum": [
                        "live",
                        "source",
                        "viewer"
                    ],
                    "default": "live",
                    "description": "Default editing mode when opening files",
                    "enumDescriptions": [
                        "Live Preview - Edit with real-time rendering",
                        "Source - Raw Markdown source only",
                        "Viewer - Read-only rendered view"
                    ]
                },
                "flowMd.modeSwitcher": {
                    "type": "string",
                    "enum": [
                        "cycle",
                        "buttons"
                    ],
                    "default": "cycle",
                    "description": "Mode switcher button style in the editor title bar",
                    "enumDescriptions": [
                        "Cycle - Single button that cycles Live → Viewer → Source",
                        "Buttons - Show direct-jump buttons for the other two modes"
                    ]
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run build",
        "build": "npm run build:extension && npm run build:webview",
        "build:extension": "esbuild src/extension/index.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --minify",
        "build:webview": "esbuild src/webview/main.ts --bundle --outfile=dist/webview.js --format=iife --platform=browser --sourcemap --minify --loader:.css=text",
        "watch": "node esbuild.config.mjs --watch",
        "watch:extension": "esbuild src/extension/index.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
        "watch:webview": "esbuild src/webview/main.ts --bundle --outfile=dist/webview.js --format=iife --platform=browser --sourcemap --watch --loader:.css=text",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js",
        "typecheck": "tsc --noEmit",
        "package:vsix": "npx @vscode/vsce package --no-dependencies --skip-license -o ./lyjy-obsidianlike-md.vsix"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^20.x",
        "@types/vscode": "^1.85.0",
        "@typescript-eslint/eslint-plugin": "^6.x",
        "@typescript-eslint/parser": "^6.x",
        "@vitest/coverage-v8": "^4.0.18",
        "@vscode/test-electron": "^2.x",
        "esbuild": "^0.19.x",
        "eslint": "^8.x",
        "happy-dom": "^20.5.0",
        "mocha": "^11.7.5",
        "prettier": "^3.x",
        "typescript": "^5.x",
        "vitest": "^4.0.18"
    },
    "dependencies": {
        "@codemirror/commands": "^6.10.1",
        "@codemirror/lang-markdown": "^6.5.0",
        "@codemirror/language": "^6.12.1",
        "@codemirror/language-data": "^6.5.2",
        "@codemirror/search": "^6.6.0",
        "@codemirror/state": "^6.5.4",
        "@codemirror/view": "^6.39.12",
        "@lezer/common": "^1.5.1",
        "katex": "^0.16.28",
        "marked": "^16.2.0",
        "mermaid": "^11.12.2"
    }
}
